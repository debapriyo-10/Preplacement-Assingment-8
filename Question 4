'''
class Node:
    def _init_(self, val):
        self.right = None
        self.data = val
        self.left = None
'''
class Solution:
    def mirror(self, root):
        # Code here
        
        if root is None:
            return None
        left_mirror = self.mirror(root.left)
        right_mirror = self.mirror(root.right)

        root.left = right_mirror
        root.right = left_mirror

        return root
